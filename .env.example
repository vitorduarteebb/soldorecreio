# MySQL (Hostinger / produção)
# Ex.: mysql://USUARIO:SENHA@HOST:3306/NOME_DO_BANCO?connection_limit=5
DATABASE_URL="mysql://user:password@localhost:3306/soldorecreio"

# Obrigatório se NODE_ENV=production (Hostinger costuma usar). Sem isso: 500 na sessão.
AUTH_SECRET="defina_um_segredo_longo_em_producao"
# NEXTAUTH_SECRET="..."  # mesmo valor que AUTH_SECRET, se preferir

# URL pública — SEM barra no final. Pode usar AUTH_URL ou NEXTAUTH_URL (o app sincroniza).
# AUTH_URL="https://silver-sheep-181616.hostingersite.com"
# NEXTAUTH_URL="https://silver-sheep-181616.hostingersite.com"
AUTH_URL="http://localhost:3000"

# Google OAuth (Console: https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: https://SEU_DOMINIO/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Mesmo ID do cliente (público) — usado só para exibir o botão "Continuar com Google"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
